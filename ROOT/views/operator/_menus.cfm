	<div class="btn-group btn-group-sm" role="group">
		<button type="submit" class="btn #button.session# text-uppercase" formaction="#URLFor(controller="system",action="sessions",key="server")#"><i class="fal fa-network-wired fa-fw fa-lg"></i> Sessions</button>
		<button type="button" class="btn #button.session# dropdown-toggle" data-toggle="dropdown">
