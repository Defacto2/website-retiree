<!---
  	Accounts menu partial view.
	path: views/operator/_menus.cfm

	Embedded into and used by layout.cfm.

@CFLintIgnore
--->
<cfscript>
	var sysop = "sysop"
	var active = " active"
	var default = "btn-default"
	var info = "btn-info"
	var primary = "btn-primary"
	var approveLimit = 35 // maximum number of records to approve in a batch
	var showAllMenus = function() {
		// set to true to show all menu items for debugging
		// otherwise in production, there are conditional items based on database statistics
		return false
	}
	var sami = showAllMenus()
	var adminer = function() {
		if(cgi.server_name == "localhost") {
			return "http://localhost:8558/"
		}
		return "https://#application.domain#/data-inno"
	}
	var buttons = function() {
		switch(params.controller){
			case "admin":
				button.database = primary
				break;
			case "file":
				button.art = primary
			break;
			case "link":
				button.web = primary
			break;
			case "operator":
				button.operator = primary
			break;
			case "person": case "organisation":
				button.database = primary
			break;
			case "system":
				switch(params.action){
					case "person":
						button.database = primary
					break;
					case "json":
						button.api = primary
					break;
					case "files":
						if(structKeyExists(params, "key") and listFindNoCase("approveall;index", "#params.key#", ";")) {
							button.art = primary
						}
						else button.thumb = primary;
					break;
					case "session": case "sessions":
						button.session = primary
					break;
					case "link":
						button.web = primary
					break;
					default:
						button.system = primary
					break;
				}
			break;
		}
	}
	var clocks = function() {
		var utc = DateConvert("local2Utc", Now())
		var hk = dateAdd("h",8,utc)
		var la = dateAdd("h",-7,utc)
		date.utc = LSDateFormat(utc, "medium")
		time.utc = LSTimeFormat(utc, "H:mm")
		date.hongKong = LSDateFormat(hk, "medium")
		time.hongKong = LSTimeFormat(hk, "H:mm")
		date.losAngeles = LSDateFormat(la, "medium")
		time.losAngeles = LSTimeFormat(la, "H:mm")
	}
	var environments = function() {
		switch(get("environment")){
			case "production":
				environment.label = "ONLINE"
				environment.icon = "globe"
				environment.button = "btn-success"
				environment.production = active;
			break;
			case "testing":
				environment.label = "TEST"
				environment.icon = "wrench"
				environment.button = "btn-warning"
				environment.testing = active;
			break;
			case "development":
				environment.label = "DEVELOPMENT"
				environment.icon = "code"
				environment.button = "btn-danger"
				environment.development = active;
			break;
			case "maintenance":
				environment.label = "OFFLINE"
				environment.icon = "exclamation-circle"
				environment.button = "btn-danger"
				environment.maintenance = active;
			break;
			default:
		}
	}
	var filesLink = function(string key = "") {
		var name = "fileFilter"
		if(arguments.key == "-") name = "fileList";
		// NOTE: the links generated by this function that have the "jsopmenus" class
		// appended to them, this can be edited in `operator.js` queryStringBase() func.
		return URLFor(route=name,key=arguments.key)
	}
	var links = function() {
		var userIP = Trim(cgi.remote_addr)
		var ignore = Trim(get("ipExceptions"))
		if(Len(userIP)) {
			var new = userIP
			if(ListLen(ignore)) {
				if (!ListFind(ignore,userIP)) new = ignore & ',' & userIP
				if (ListFind(ignore,userIP)) new = ignore
			}
			except = ReplaceNoCase(new,' ','','all')
			set(ipExceptions="#ReplaceNoCase(new,' ','','all')#")
		}
		link.environment = URLFor(params="except=#get("ipExceptions")#&password=#get("reloadPassword")#")
		link.maintenance = URLFor(params="&password=#get("reloadPassword")#")
	}
	var loggedInUser = function() {
		// fetch the account of the logged in user, which is used for self editing of account
		return model("operator").findOneByUUID(value=session.op.uuid,returnAs="query")
	}
	var luceeAdmin = function() {
		// lucee on java menu items
		if(cgi.server_port == "80" && cgi.script_name == "/index.cfm") {
			return "http://localhost:8888/lucee/admin"
		}
		return "/lucee/admin"
	}
	var button={
		"api":default,
		"art":default,
		"database":default,
		"operator":default,
		"session":info,
		"system": info,
		"thumb":default,
		"web":default
	}
	var environment={
		"button":"",
		"label":"",
		"icon":"",
		"development":"",
		"maintenance":"",
		"production":"",
		"testing":""
	}
	var link={
		"environment":"",
		"maintenance":"",
		"reload":""
	}

	var date={
		"hongKong":"",
		"losAngeles":"",
		"utc":""
	}
	var time={
		"hongKong":"",
		"losAngeles":"",
		"utc":""
	}
	links()
	environments()
	buttons()
	clocks()
	var superUser = loggedInUser()
</cfscript>
<cfoutput>
<form method="post">
<!--- ---- --->
<!--- QUIT --->
<!--- ---- --->
