		<button type="button" class="btn btn-default #environment.button# dropdown-toggle" data-toggle="dropdown">
			<span class="caret"></span>
			<span class="sr-only">Toggle Dropdown</span>
		</button>
		<ul class="dropdown-menu" role="menu" aria-labelledby="switch_environment">
			<li class="dropdown-header">Switch Environments</li>
			<li class="divider"></li>
			<li class="#environment.production#"><a href="#link.environment#&reload=production"><i class="fal fa-globe fa-fw brand-success"></i> Production</a></li>
			<li class="divider"></li>
			<li class="#environment.testing#"><a href="#link.environment#&reload=testing"><i class="fal fa-wrench fa-fw brand-warning"></i> Test</a></li>
			<li class="#environment.development#"><a href="#link.environment#&reload=development"><i class="fal fa-brackets-curly fa-fw brand-danger"></i> Development</a></li>
			<li class="divider"></li>
