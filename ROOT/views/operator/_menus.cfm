			<li class="dropdown-header">Cache<br></li>
			<li><a href="#UrlFor(controller="system", action="cachereset",rel="nofollow")#"><i class="fal fa-redo fa-fw brand-success"></i> Reset server</a></li>
			<li class="divider"></li>
			<li class="dropdown-header">
