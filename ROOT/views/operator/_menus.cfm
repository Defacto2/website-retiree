					Production Error Tests<br>
					<strong>environment must<br>be set to production</strong>
				</span><br>
			<cfelse>
				Production Error Tests<br>
			</cfif>
			</li>
			<li><a href="#UrlFor(controller="system", action="testhtml5error",rel="nofollow")#"><i class="fal fa-file-times fa-fw brand-danger"></i> 500 <small>html5</small></a></li>
			<li><a href="#UrlFor(controller="html3", action="testhtml3error",rel="nofollow")#"><i class="fal fa-file-times fa-fw brand-danger"></i> 500 <small>html3</small></a></li>
			<li><a href="#UrlFor(controller="system", action="notfound",rel="nofollow")#"><i class="fal fa-file-exclamation fa-fw brand-warning"></i> 404 <small>html5</small></a></li>
			<li><a href="#UrlFor(controller="html3", action="notfound",rel="nofollow")#"><i class="fal fa-file-exclamation fa-fw brand-warning"></i> 404 <small>html3</small></a></li>
		</ul>
	</div>
</cfif>
<!--- ----- --->
<!--- TOOLS --->
<!--- ----- --->
